---
import AvatarFlip from "./AvatarFlip.tsx";
import HeroTerminal from "./HeroTerminal.tsx";
import IconCloud from "./IconCloud.tsx";
import ProjectCard from "./ProjectCard.astro";
import ContactForm from "./ContactForm.tsx";
import ContactChannels from "./ContactChannels.tsx";
import Mailbox3D from "./Mailbox3D.tsx";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import { getImage } from "astro:assets";
import luisPhoto from "../assets/luis-felipe.jpg";
import { useStrings, type Locale } from "../i18n/ui";
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useStrings(locale);

// Keep the in-page contact anchor on the current locale's home route.
const contactHref = `${getRelativeLocaleUrl(locale, "")}#contact`;

// Pre-optimize the portrait to responsive WebP so the flip island (a client
// component that can't use Astro's <Image>) still gets a proper srcset.
const photo = await getImage({
  src: luisPhoto,
  widths: [400, 512, 768, 1024],
  format: "webp",
});

// Featured strip: explicit order for the home grid (2×2).
const featuredSlugs = [
  "deliverychat",
  "ai-site-builder",
  "63-west",
  "render-delivery-platform",
] as const;

const allProjects =
  locale === "pt"
    ? await getCollection("projectsPt")
    : await getCollection("projects");
const featured = featuredSlugs
  .map((slug) => allProjects.find((p) => p.id === slug))
  .filter((p): p is (typeof allProjects)[number] => p != null);

// Skills cloud: tech logos from the Simple Icons CDN, in brand colors. A few
// brands are near-black (Next, Vercel, OpenAI, GitHub) and would vanish on the
// dark base, so those are tinted to the `fg` token instead.
const fg = "e6e6e6";
const brand = (slug: string) => `https://cdn.simpleicons.org/${slug}`;
const onDark = (slug: string) => `https://cdn.simpleicons.org/${slug}/${fg}`;
const skillIcons = [
  brand("typescript"),
  brand("react"),
  onDark("nextdotjs"),
  brand("astro"),
  brand("nodedotjs"),
  brand("tailwindcss"),
  brand("postgresql"),
  brand("drizzle"),
  brand("trpc"),
  brand("hono"),
  brand("zod"),
  brand("redis"),
  brand("stripe"),
  brand("sanity"),
  brand("docker"),
  brand("git"),
  brand("python"),
  onDark("openai"),
  onDark("vercel"),
  onDark("github"),
];
---

<div class="flex flex-col gap-16">
  <div class="flex flex-col gap-8">
    <div class="flex justify-start">
      <LanguageSwitcher locale={locale} />
    </div>
    <section class="grid items-center gap-10 md:grid-cols-[1fr_auto]">
      <div class="flex flex-col gap-8">
        <HeroTerminal
          client:load
          name={t.brand}
          role={t.role}
          promptWhoami={t.home.hero.promptWhoami}
          promptContact={t.home.hero.promptContact}
        />

        <div class="flex flex-wrap gap-3 font-mono text-sm">
          <a
            href={contactHref}
            class="border border-accent px-4 py-2 text-accent transition-colors hover:bg-accent hover:text-base"
          >
            {t.cta.talk} →
          </a>
          <a
            href="/Luis-Felipe-CV.pdf"
            download
            class="border border-border px-4 py-2 text-fg transition-colors hover:border-accent hover:text-accent"
          >
            {t.cta.downloadCv} ↓
          </a>
        </div>
      </div>

      <div class="flex justify-center">
        <IconCloud client:idle images={skillIcons} size={440} />
      </div>
    </section>

    <section class="grid items-center gap-10 md:grid-cols-[1fr_32rem]">
      <div class="flex flex-col gap-4">
        <h2 class="font-mono text-2xl font-semibold tracking-tight">
          <span class="text-accent">~/</span><span data-typewriter
            >{t.home.about.heading}</span
          >
        </h2>
        <div
          class="prose-readable flex max-w-2xl flex-col gap-4 text-muted"
          data-reveal-children
        >
          {t.home.about.body.map((paragraph) => <p>{paragraph}</p>)}
        </div>

        <dl class="grid grid-cols-2 gap-px border border-border bg-border sm:grid-cols-4">
          {
            t.home.about.stats.map((stat) => (
              <div class="flex flex-col gap-1 bg-base p-3">
                <dt class="font-mono text-xl font-semibold text-accent">
                  {stat.value}
                </dt>
                <dd class="font-mono text-[11px] leading-snug text-muted">
                  {stat.label}
                </dd>
              </div>
            ))
          }
        </dl>

        <p class="flex flex-wrap items-center gap-x-2 gap-y-1 font-mono text-xs text-muted">
          <span class="text-accent">~/</span>
          {
            t.home.about.status.map((item, i) => (
              <>
                {i > 0 && <span class="text-border">·</span>}
                <span>{item}</span>
              </>
            ))
          }
        </p>

        <div class="flex flex-wrap gap-1.5">
          {
            t.home.about.badges.map((badge) => (
              <span class="border border-border bg-base/60 px-2 py-0.5 font-mono text-[10px] text-muted">
                {badge}
              </span>
            ))
          }
        </div>
      </div>

      <div class="mx-auto w-full max-w-[32rem] md:mx-0 md:ml-auto">
        <AvatarFlip
          client:visible
          photoSrc={photo.src}
          photoSrcSet={photo.srcSet.attribute}
          alt={`${t.brand} — ${t.role}`}
        />
      </div>
    </section>
  </div>

  <section class="flex flex-col gap-6">
    <div class="flex items-baseline justify-between gap-4">
      <h2 class="font-mono text-2xl font-semibold tracking-tight">
        <span class="text-accent">~/</span><span data-typewriter
          >{t.home.featured.heading}</span
        >
      </h2>
      <a
        href={getRelativeLocaleUrl(locale, "projects")}
        class="font-mono text-sm text-muted transition-colors hover:text-accent"
      >
        {t.home.featured.viewAll} →
      </a>
    </div>
    <div class="grid gap-6 sm:grid-cols-2">
      {
        featured.map((project, i) => (
          <ProjectCard project={project} index={i} locale={locale} />
        ))
      }
    </div>
  </section>

  <section
    id="contact"
    class="grid scroll-mt-24 items-start gap-10 md:grid-cols-[1fr_28rem] md:items-stretch"
  >
    <div class="flex flex-col gap-6">
      <div class="flex flex-col gap-2">
        <h2 class="font-mono text-2xl font-semibold tracking-tight">
          <span class="text-accent">~/</span><span data-typewriter
            >{t.home.contact.heading}</span
          >
        </h2>
        <p class="prose-readable max-w-xl text-muted" data-reveal>
          {t.home.contact.lead}
        </p>
      </div>

      <ContactForm
        client:visible
        strings={t.home.contact.form}
        email={t.home.contact.email}
        copyLabel={t.home.contact.copyEmail}
        copiedLabel={t.home.contact.copied}
      />

      <ContactChannels
        client:visible
        email={t.home.contact.email}
        linkedinUrl={t.socials.linkedin}
        githubUrl={t.socials.github}
      />
    </div>

    <div class="flex h-full justify-center md:justify-end">
      <Mailbox3D client:visible />
    </div>
  </section>
</div>
