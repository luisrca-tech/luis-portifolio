---
import { useStrings, type Locale } from "../i18n/ui";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const t = useStrings(locale);
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-border">
  <div
    class="mx-auto flex max-w-5xl flex-col gap-2 px-6 py-8 font-mono text-xs text-muted sm:flex-row sm:items-center sm:justify-between"
  >
    <p>
      <span class="text-accent">$</span>
      {t.footer.builtWith}
    </p>
    <p>© {year} {t.brand}. {t.footer.rights}</p>
  </div>
</footer>
