---
import { useStrings, type Locale } from "../i18n/ui";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const t = useStrings(locale);
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-border">
  <div
    class="mx-auto flex max-w-6xl flex-col gap-2 px-6 py-8 font-mono text-xs text-muted sm:flex-row sm:items-center sm:justify-between"
  >
    <p>
      <span class="text-accent">$</span>
      {t.footer.builtWith}
    </p>
    <div class="flex items-center gap-4">
      <a
        href={t.socials.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:text-accent">LinkedIn ↗</a
      >
      <a
        href={t.socials.github}
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:text-accent">GitHub ↗</a
      >
      <span>© {year} {t.brand}. {t.footer.rights}</span>
    </div>
  </div>
</footer>
