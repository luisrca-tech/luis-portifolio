# Resend API key (create at https://resend.com/api-keys — "Sending access" is enough)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where contact-form messages are delivered.
# On Resend's free tier (no verified domain) this MUST be your Resend account email.
CONTACT_TO_EMAIL=you@example.com

# Sender address shown on contact emails.
# Free tier (no verified domain) MUST use Resend's shared sender below.
# Switch to an address on your own verified domain once you add one.
CONTACT_FROM_EMAIL=onboarding@resend.dev
